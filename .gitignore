# Rust / Cargo
companion/target/
companion/Cargo.lock
**/*.rs.bk
*.pdb

# Build artifacts
*.exe
*.dll
*.so
*.dylib

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs & runtime data
*.log
companion/tor-data/
companion/tor-bin/

# Extension build output
extension/web-ext-artifacts/
extension/*.xpi
extension/*.zip

# Build output (compiled installer + bundled XPI + companion binary copies)
dist/
installer/build/
installer/dist/
installer/com.onionrouter.companion.json

# Local secrets / config
*.local
.env
.env.*

# GPG signing keys -- NEVER commit a private key. Only the public key
# docs/onionrouter-signing-key.asc is meant to be tracked (force-add it).
*-private.asc
*-secret*.asc
*.gpg
*.key

# Claude / agent artifacts (keep project settings, ignore local-only files)
.claude/settings.local.json
.claude/cache/
.claude/projects/*/sessions/

# Affinity/source art (keep PNG/ICO outputs only)
*.af

# Affinity source art (local only, not shipped)
art-sources/
